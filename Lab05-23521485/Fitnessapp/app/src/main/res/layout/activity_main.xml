<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header: Quest Title -->
        <TextView
            android:id="@+id/titleQuest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/title_dashboard"
            android:textColor="@color/text_accent"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitleQuest"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Your fitness journey awaits, hero!"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/titleQuest"
            app:layout_constraintStart_toStartOf="@id/titleQuest"
            app:layout_constraintTop_toBottomOf="@id/titleQuest" />

        <!-- Stats Row: Steps, Calories, Points -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSteps"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/card_background"
            app:layout_constraintEnd_toStartOf="@id/cardCalories"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitleQuest">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iconSteps"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_steps"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/labelCardSteps"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/label_today_steps"
                    app:layout_constraintBottom_toBottomOf="@id/iconSteps"
                    app:layout_constraintStart_toEndOf="@id/iconSteps"
                    app:layout_constraintTop_toTopOf="@id/iconSteps" />

                <TextView
                    android:id="@+id/valueSteps"
                    style="@style/StatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textSize="32sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iconSteps" />

                <TextView
                    android:id="@+id/labelStepsGoal"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/format_progress"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/valueSteps"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCalories"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:layout_constraintEnd_toStartOf="@id/cardPoints"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/cardSteps"
            app:layout_constraintTop_toBottomOf="@id/subtitleQuest">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iconCalories"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_fire"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/labelCardCalories"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/label_calories_burned"
                    app:layout_constraintBottom_toBottomOf="@id/iconCalories"
                    app:layout_constraintStart_toEndOf="@id/iconCalories"
                    app:layout_constraintTop_toTopOf="@id/iconCalories" />

                <TextView
                    android:id="@+id/valueCalories"
                    style="@style/StatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0.0"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iconCalories" />

                <TextView
                    android:id="@+id/labelCalUnit"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="cal"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/valueCalories"
                    app:layout_constraintStart_toEndOf="@id/valueCalories" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPoints"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/cardCalories"
            app:layout_constraintTop_toBottomOf="@id/subtitleQuest">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iconPoints"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_trophy"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/labelCardPoints"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/label_points_earned"
                    app:layout_constraintBottom_toBottomOf="@id/iconPoints"
                    app:layout_constraintStart_toEndOf="@id/iconPoints"
                    app:layout_constraintTop_toTopOf="@id/iconPoints" />

                <TextView
                    android:id="@+id/valuePoints"
                    style="@style/StatValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="0"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/iconPoints" />

                <TextView
                    android:id="@+id/labelPointsUnit"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pts"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/valuePoints"
                    app:layout_constraintStart_toEndOf="@id/valuePoints" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Level Badge -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLevel"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardSteps">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelLevel"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_level"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/valueLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Novice"
                    android:textColor="@color/accent"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="12dp"
                    android:max="10000"
                    android:progressDrawable="@drawable/progress_bar_step"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelLevel" />

                <TextView
                    android:id="@+id/progressText"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0 / 10,000"
                    android:textColor="@color/text_accent"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progressBar" />

                <TextView
                    android:id="@+id/nextMilestone"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/label_next_milestone"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progressBar" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Badges Section -->
        <TextView
            android:id="@+id/labelBadges"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/title_badges"
            android:textColor="@color/text_accent"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardLevel" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardBadges"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelBadges">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Bronze Badge -->
                <LinearLayout
                    android:id="@+id/badgeBronze"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconBadgeBronze"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_badge_bronze"
                        android:contentDescription="@string/milestone_1000"
                        android:src="@drawable/ic_steps" />

                    <TextView
                        android:id="@+id/labelBadgeBronze"
                        style="@style/BadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/milestone_1000"
                        android:textSize="10sp" />

                </LinearLayout>

                <!-- Silver Badge -->
                <LinearLayout
                    android:id="@+id/badgeSilver"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconBadgeSilver"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_badge_silver"
                        android:contentDescription="@string/milestone_5000"
                        android:src="@drawable/ic_steps" />

                    <TextView
                        android:id="@+id/labelBadgeSilver"
                        style="@style/BadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/milestone_5000"
                        android:textSize="10sp" />

                </LinearLayout>

                <!-- Gold Badge -->
                <LinearLayout
                    android:id="@+id/badgeGold"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconBadgeGold"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_badge_gold"
                        android:contentDescription="@string/milestone_10000"
                        android:src="@drawable/ic_trophy" />

                    <TextView
                        android:id="@+id/labelBadgeGold"
                        style="@style/BadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/milestone_10000"
                        android:textSize="10sp" />

                </LinearLayout>

                <!-- Platinum Badge -->
                <LinearLayout
                    android:id="@+id/badgePlatinum"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconBadgePlatinum"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_badge_platinum"
                        android:contentDescription="@string/milestone_25000"
                        android:src="@drawable/ic_trophy" />

                    <TextView
                        android:id="@+id/labelBadgePlatinum"
                        style="@style/BadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/milestone_25000"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Motivational Quote -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardQuote"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardBadges">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/labelMotivation"
                    style="@style/StatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_motivation"
                    android:textColor="@color/text_accent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textQuote"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Your journey begins now..."
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="italic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/labelMotivation" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Gemini AI Coach -->
        <TextView
            android:id="@+id/labelGemini"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/title_gemini"
            android:textColor="@color/text_accent"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardQuote" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardGemini"
            style="@style/CardStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelGemini">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <EditText
                    android:id="@+id/inputApiKey"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card"
                    android:hint="@string/gemini_api_key_hint"
                    android:importantForAutofill="no"
                    android:inputType="textVisiblePassword"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/btnGenerate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:padding="12dp"
                    android:text="@string/label_generate"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/inputApiKey" />

                <TextView
                    android:id="@+id/textSuggestion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:minHeight="40dp"
                    android:text=""
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnGenerate" />

                <TextView
                    android:id="@+id/textEncouragement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="40dp"
                    android:text=""
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/textSuggestion" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Spacer at bottom -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp"
            app:layout_constraintTop_toBottomOf="@id/cardGemini" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
